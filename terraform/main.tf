terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

# This is the random suffix generator that prevents name clashes on AWS
resource "random_string" "suffix" {
  length  = 6
  special = false
  upper   = false
}